# ============================================================================
# CreatosConnect Backend Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual API keys and configuration
# Command: cp .env.example .env
#
# All fields marked as [REQUIRED] must be set for the application to function
# Fields marked as [OPTIONAL] have sensible defaults if not provided
# ============================================================================

# ============================================================================
# APPLICATION & SERVER CONFIGURATION
# ============================================================================
APP_NAME=CreatosConnect
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Secret for token generation and validation [REQUIRED]
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Default credentials for demo access [OPTIONAL]
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123

# ============================================================================
# OPENAI API CONFIGURATION [REQUIRED if using OpenAI models]
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============================================================================
# ALTERNATIVE AI MODEL PROVIDERS
# ============================================================================

# Google Gemini API [OPTIONAL]
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# Groq API (LLaMA models) [OPTIONAL]
# Get API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API (aggregates multiple models) [OPTIONAL]
# Get API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER_URL=https://creatosconnect.com
OPENROUTER_TIMEOUT=60

# ============================================================================
# WEB SEARCH & INFLUENCER DISCOVERY
# ============================================================================

# SerpAPI for web search results [REQUIRED for discovery feature]
# Get API key from: https://serpapi.com/
SERP_API_KEY=your-serpapi-key-here
SERPAPI_SEARCH_URL=https://serpapi.com/search
SERPAPI_TIMEOUT=20

# Instagram Influencer Data URLs [OPTIONAL]
INSTAGRAM_BASE_URL=https://www.instagram.com
SPREADD_URL=https://spreadd.io

# ============================================================================
# PROFILE ENRICHMENT & METRICS SCRAPING
# ============================================================================

# BrightData API for detailed profile scraping [OPTIONAL]
# Get credentials from: https://brightdata.com/
BRIGHTDATA_API_KEY=your-brightdata-api-key-here
BRIGHTDATA_DATASET_ID=your-brightdata-dataset-id-here
BRIGHTDATA_API_BASE=https://api.brightdata.com
BRIGHTDATA_SCRAPE_PATH=/datasets/v3/scrape
BRIGHTDATA_TIMEOUT_SECONDS=45

# ============================================================================
# INFLUENCER DATASET PATHS
# ============================================================================

# Path to local influencer dataset CSV (for static search)
# This can be absolute path or relative to project root
INFLUENCER_DATA_PATH=/path/to/influencers_dataset.csv

# Path to dynamic dataset directory (for dynamic search results)
DYNAMIC_DATASET_PATH=./storage/dynamic_results/

# ============================================================================
# FILE STORAGE & UPLOADS
# ============================================================================

# Base directory for file uploads [OPTIONAL - defaults to ./storage/uploads/]
UPLOADS_DIR=./storage/uploads/

# Base directory for generated reports [OPTIONAL - defaults to ./storage/reports/]
REPORTS_DIR=./storage/reports/

# Base directory for search results [OPTIONAL - defaults to ./storage/results/]
RESULTS_DIR=./storage/results/

# Maximum upload file size in MB [OPTIONAL - defaults to 50]
MAX_UPLOAD_SIZE_MB=50

# ============================================================================
# DATABASE CONFIGURATION [OPTIONAL]
# ============================================================================

# SQLite database path (for future use)
DATABASE_URL=sqlite:///./creatosconnect.db

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS [OPTIONAL - defaults to localhost:3000]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# RATE LIMITING & THROTTLING [OPTIONAL]
# ============================================================================

# API rate limits (requests per minute)
RATE_LIMIT_SEARCH_PER_MIN=10
RATE_LIMIT_ANALYSIS_PER_MIN=5
RATE_LIMIT_PDF_GENERATION_PER_MIN=3

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry DSN for error tracking [OPTIONAL]
SENTRY_DSN=

# Log file path [OPTIONAL]
LOG_FILE_PATH=./logs/app.log

# Enable detailed request/response logging
ENABLE_REQUEST_LOGGING=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
ENABLE_DYNAMIC_SEARCH=true
ENABLE_STATIC_SEARCH=true
ENABLE_PDF_GENERATION=true
ENABLE_AGENT_CHAT=true
ENABLE_METRICS_DASHBOARD=true

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Reload server on file changes (development only)
RELOAD=true

# Enable debug mode for verbose logging
DEBUG_MODE=false

# Mock external APIs for testing (development only)
MOCK_SERPAPI=false
MOCK_BRIGHTDATA=false
MOCK_SPREADD=false
